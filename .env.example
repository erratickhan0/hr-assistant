APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
CV_UPLOAD_DISK=cv_uploads
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# Bucket name (when NOT using an access point ARN in AWS_BUCKET_ACCESS_POINT_ARN)
AWS_BUCKET=
#
# If you use an S3 Access Point, put its ARN here (recommended) and you can leave AWS_BUCKET empty:
# AWS_BUCKET_ACCESS_POINT_ARN=arn:aws:s3:REGION:ACCOUNT_ID:accesspoint/AP_NAME
AWS_BUCKET_ACCESS_POINT_ARN=
#
# Optional: public base URL used by Storage::url() when objects are publicly readable.
# Common examples:
# - CloudFront: https://d111111abcdef8.cloudfront.net
# - S3 website endpoint: http://YOUR_BUCKET.s3-website-REGION.amazonaws.com
# Leave empty for private buckets (use signed URLs / temporaryUrl() instead).
AWS_URL=
#
# Optional: custom S3-compatible API endpoint (MinIO, LocalStack, etc.). Leave empty for real AWS.
# Example (MinIO): http://127.0.0.1:9000
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Optional dedicated credentials for CV uploads. If left empty, app falls back to AWS_* above.
CV_UPLOAD_AWS_ACCESS_KEY_ID=
CV_UPLOAD_AWS_SECRET_ACCESS_KEY=
CV_UPLOAD_AWS_DEFAULT_REGION=
CV_UPLOAD_AWS_BUCKET=
CV_UPLOAD_AWS_URL=
CV_UPLOAD_AWS_ENDPOINT=
CV_UPLOAD_AWS_USE_PATH_STYLE_ENDPOINT=false
#
# Helpful URL shapes (for humans / infra docs — Laravel does not need all of these):
# - Virtual-hosted style object URL:
#   https://BUCKET.s3.REGION.amazonaws.com/KEY
# - Path-style object URL (legacy / some tools):
#   https://s3.REGION.amazonaws.com/BUCKET/KEY
# - Access point alias style (console shows alias + account id):
#   https://ALIAS-ACCOUNT_ID.s3-accesspoint.REGION.amazonaws.com/KEY

VITE_APP_NAME="${APP_NAME}"

# OpenAI (embeddings for CV + HR query text)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=512
# Short HR answers (RAG over extracted CV text)
OPENAI_ANSWER_MODEL=gpt-4o-mini

# Pinecone (vector index — vectors are not stored in SQL)
PINECONE_API_KEY=
PINECONE_INDEX_HOST=
PINECONE_INDEX_NAME=
